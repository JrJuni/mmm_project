# Copy to .env and fill in locally. NEVER commit .env or paste keys into chat.
#
# SerpApi key (free tier is enough for 1 keyword / daily refresh).
# Get one at https://serpapi.com/manage-api-key
# Tip: name/alias the key per user in the SerpApi dashboard for per-key usage
# monitoring and blast-radius isolation.
SERPAPI_KEY=replace-with-your-serpapi-key

# Your primary tracked brand/keyword (the GEO_MAP grid, WoW, and MCP use it).
# This keeps the brand out of the committed repo. Add competitors for the Trend
# comparison with `python -m collector.admin set-keywords A B C`.
MMM_KEYWORD=YourBrand
